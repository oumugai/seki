-- ===========================================================
-- tests/seki/test_analysis_series.seki — 級数と Taylor
-- ===========================================================

import "../../lib/analysis/series.seki"

def absR := \r -> if r < 0.0 then 0.0 - r else r

-- ----- 階乗 -----
theorem fact_0 : factorial 0 == 1 := by eval
theorem fact_5 : factorial 5 == 120 := by eval

-- ----- 部分和: Σ_{k=0}^{n-1} k = n(n-1)/2 -----
def identityTerm := \k -> intToReal k
theorem partial_sum_id
  : absR (partialSum 10 identityTerm - 45.0) < 0.000001 := by eval

-- ----- e^x の Taylor (x=1 で e に収束) -----
theorem exp_at_1
  : absR (expTaylor 20 1.0 - e) < 0.000001 := by eval

-- e^0 = 1
theorem exp_at_0
  : absR (expTaylor 10 0.0 - 1.0) < 0.000001 := by eval

-- e^(-1) = 1/e ≈ 0.3679
theorem exp_at_neg1
  : absR (expTaylor 20 (0.0 - 1.0) - (1.0 / e)) < 0.000001 := by eval

-- ----- sin(0) = 0, sin(π/2) ≈ 1, sin(π) ≈ 0 -----
theorem sin_at_0
  : absR (sinTaylor 10 0.0 - 0.0) < 0.000001 := by eval

theorem sin_at_pi_half
  : absR (sinTaylor 20 (pi / 2.0) - 1.0) < 0.000001 := by eval

theorem sin_at_pi
  : absR (sinTaylor 30 pi - 0.0) < 0.001 := by eval

-- ----- cos(0) = 1, cos(π) ≈ -1 -----
theorem cos_at_0
  : absR (cosTaylor 10 0.0 - 1.0) < 0.000001 := by eval

theorem cos_at_pi
  : absR (cosTaylor 30 pi - (0.0 - 1.0)) < 0.001 := by eval

-- ----- ln(1+x): ln(1) = 0, ln(1.5) ≈ 0.4055 -----
theorem ln_at_0
  : absR (lnTaylor 20 0.0 - 0.0) < 0.000001 := by eval

-- ln(1.5) = ln(1 + 0.5) で Taylor は |x|<1 で収束
def ln_15 := 0.405465108108164
theorem ln_at_0_5
  : absR (lnTaylor 50 0.5 - ln_15) < 0.0001 := by eval

-- ----- Leibniz 級数: π/4 = 1 - 1/3 + 1/5 - ... (収束は遅い) -----
-- n=1000 項で π/4 ≈ 0.7853 (誤差 ~0.001 程度)
def pi_over_4 := pi / 4.0
theorem leibniz_pi
  : absR (piLeibniz 1000 - pi_over_4) < 0.01 := by eval

-- ----- 調和数: H_4 = 1 + 1/2 + 1/3 + 1/4 = 25/12 ≈ 2.0833 -----
theorem harmonic_4
  : absR (harmonicNumber 4 - (25.0 / 12.0)) < 0.000001 := by eval
