-- ===========================================================
-- tests/seki/test_analysis_advanced.seki — Grönwall / Taylor /
--                                            多変数微分
-- ===========================================================

import "../../lib/analysis/gronwall.seki"
import "../../lib/analysis/taylor.seki"
import "../../lib/analysis/multidiff.seki"
import "../../lib/numeric/linalg.seki"

def absA := \(r : Real) -> if r < 0.0 then 0.0 - r else r

-- ----- Grönwall: u' ≤ 1*u, u_0=1 ⇒ u(1) ≤ e -----
theorem gronwall_exp
  : absA (gronwallScalar 1.0 0.0 1.0 1.0 - 2.718281828459045) < 0.00001
  := by eval

-- α = 0 の線型バウンド: u(t) ≤ u_0 + β t
theorem gronwall_linear
  : gronwallScalar 0.0 2.0 1.0 3.0 == 7.0
  := by eval

-- 離散版: u_{n+1} ≤ 2 u_n + 1, u_0=1, n=3 ⇒ u_3 ≤ 2^3 * 1 + 1*(8-1)/(2-1) = 15
theorem gronwall_discrete_test
  : absA (gronwallDiscrete 2.0 1.0 1.0 3 - 15.0) < 0.00001
  := by eval

-- ----- Taylor: exp(1) を x0=0 から 15 項で展開 ≈ 2.71828 -----
theorem taylor_exp_1
  : absA (taylorExpAt 1.0 0.0 15 - 2.718281828459045) < 0.00001
  := by eval

-- sin(π/2) ≈ 1 (10 項で十分)
theorem taylor_sin_pi_2
  : absA (taylorSinAt 1.5707963267948966 0.0 10 - 1.0) < 0.0001
  := by eval

-- Lagrange 残差バウンド: f^(3) bound = 6, h = 0.1 ⇒ |R_3| ≤ 6 * 0.001 / 6 = 0.001
theorem taylor_remainder
  : absA (lagrangeRemainderBound 6.0 0.1 3 - 0.001) < 0.00001
  := by eval

-- ----- 多変数微分: 勾配 -----
def f_quad := \xs -> (listAtMD 0 xs) * (listAtMD 0 xs) + (listAtMD 1 xs) * (listAtMD 1 xs)
def grad_at_12 := gradient 0.0001 f_quad [1.0, 2.0]

theorem grad_x
  : absA (nth 0 grad_at_12 - 2.0) < 0.01
  := by eval

theorem grad_y
  : absA (nth 1 grad_at_12 - 4.0) < 0.01
  := by eval

-- Hessian: H_ii = 2 (対角)、H_ij = 0 (i≠j)
def H := hessian 0.01 f_quad [1.0, 2.0]

theorem hess_xx
  : absA (matAtR 0 0 H - 2.0) < 0.001
  := by eval

theorem hess_yy
  : absA (matAtR 1 1 H - 2.0) < 0.001
  := by eval

theorem hess_xy_is_zero
  : absA (matAtR 0 1 H) < 0.001
  := by eval

-- ----- Jacobian: f(x, y) = (x+y, x-y) → J = [[1, 1], [1, -1]] -----
def f_lin := \xs ->
    cons ((listAtMD 0 xs) + (listAtMD 1 xs))
         (cons ((listAtMD 0 xs) - (listAtMD 1 xs)) nil)
def J := jacobian 0.0001 f_lin [1.0, 2.0]

theorem jac_00
  : absA (matAtR 0 0 J - 1.0) < 0.001
  := by eval

theorem jac_01
  : absA (matAtR 0 1 J - 1.0) < 0.001
  := by eval

theorem jac_11
  : absA (matAtR 1 1 J - (0.0 - 1.0)) < 0.001
  := by eval
