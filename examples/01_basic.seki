-- ===========================================================
-- 01: 基本構文 — 数値・真偽値・関数・let・if
-- ===========================================================

-- リテラルと算術
1 + 2 * 3
10 mod 3
not (1 == 2)

-- ラムダ抽象 (Haskell風)
def double := \x -> x * 2
double 21

-- 多引数 (カリー化される)
def add := \x y -> x + y
add 3 4

-- 型注釈
def square : Nat -> Nat := \(n : Nat) -> n * n
square 7

-- let 束縛
let x = 5 in x * x

-- if 式
if 3 > 2 then "yes" else "no"
