-- match tcpListen "127.0.0.1" 7878 with
-- | Err e -> println e
-- | Ok listener ->
--     let _ = println "listening on 127.0.0.1:7878" in
--     match tcpAccept listener with
--     | Err e -> println e
--     | Ok sock ->
--         match tcpRead sock 1024 with
--         | Err e -> println e
--         | Ok msg ->
--             let _ = tcpWrite sock (strConcat "echo: " msg) in
--             let _ = tcpClose sock in
--             tcpClose listener
--
-- HTTP クライアントの素朴な例:
--
-- match tcpConnect "example.com" 80 with
-- | Err e -> println e
-- | Ok s ->
--     let _ = tcpWrite s "GET / HTTP/1.0\r\nHost: example.com\r\n\r\n" in
